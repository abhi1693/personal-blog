    "@sanity/preview-url-secret": "^2.1.11",
    "@sanity/vision": "^3.89.0",
    "@tailwindcss/postcss": "^4.1.7",
    "clsx": "^2.1.1",
    "feed": "^5.0.1",
    "framer-motion": "^12.12.2",
    "googleapis": "^149.0.0",
    "next": "^15.3.2",
    "next-sanity": "^9.11.1",
    "next-sanity-image": "^6.2.0",
    "nuqs": "^2.4.3",
