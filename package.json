{
	"name": "personal-blog",
	"version": "0.3.7",
	"description": "An impressive Sanity.io starter template with Next.js 15 and Tailwind 4",
	"author": "Abhimanyu Saharan <desk.abhimanyu@gmail.com> (https://blog.abhimanyu-saharan.com)",
	"scripts": {
		"dev": "next dev",
		"build": "npm run manifest && next build",
		"start": "next start",
		"lint": "eslint src scripts",
		"format": "prettier --write src/ scripts/",
		"manifest": "DO_NOT_TRACK=1 sanity manifest extract --path public/admin/static",
		"typecheck": "tsc --noEmit",
		"build:test": "tsc -p tsconfig.test.json",
		"test": "npm run build:test && node tests/run-tests.js"
	},
	"dependencies": {
		"@grafana/faro-web-sdk": "^2.8.1",
		"@grafana/faro-web-tracing": "^2.8.1",
		"@next/third-parties": "^16.2.6",
		"@portabletext/markdown": "^1.2.0",
		"@portabletext/to-html": "^5.0.2",
		"@sanity/code-input": "^7.1.2",
		"@sanity/dashboard": "^5.0.1",
		"@sanity/document-internationalization": "^6.2.1",
		"@sanity/image-url": "^2.1.1",
		"@sanity/language-filter": "^5.0.3",
		"@sanity/preview-url-secret": "^4.0.6",
		"@sanity/ui": "^3.2.0",
		"@sanity/vision": "^5.27.0",
		"@tailwindcss/postcss": "^4.3.0",
		"clsx": "^2.1.1",
		"feed": "^5.2.1",
		"framer-motion": "^12.40.0",
		"googleapis": "^172.0.0",
		"next": "16.2.6",
		"next-sanity": "^13.0.4",
		"nuqs": "^2.8.9",
		"octokit": "^5.0.5",
		"react": "^19.2.6",
		"react-device-detect": "^2.2.3",
		"react-dom": "^19.2.6",
		"react-icons": "^5.6.0",
		"react-lite-youtube-embed": "^3.5.1",
		"resend": "^6.12.4",
		"rss-parser": "^3.13.0",
		"sanity": "^6.3.0",
		"sanity-plugin-internationalized-array": "^5.1.3",
		"sanitypress-utils": "^0.0.8",
		"server-only": "^0.0.1",
		"shiki": "^4.1.0",
		"styled-components": "^6.4.2",
		"tailwind-merge": "^3.6.0",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.39.4",
		"@next/eslint-plugin-next": "^16.2.6",
		"@sanity/eslint-config-studio": "^6.0.0",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"axios": "^1.16.1",
		"eslint": "^9.39.4",
		"eslint-config-next": "^16.2.6",
		"eslint-config-prettier": "^10.1.8",
		"postcss": "^8.5.15",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4.3.0",
		"typescript": "6.0.3",
		"xml2js": "^0.6.2"
	},
	"overrides": {
		"@vercel/frameworks": {
			"js-yaml": "3.14.2"
		},
		"sanitypress-utils": {
			"@sanity/dashboard": "$@sanity/dashboard",
			"react": "$react",
			"react-dom": "$react-dom",
			"sanity": "$sanity"
		}
	}
}
