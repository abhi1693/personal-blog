    "@sanity/document-internationalization": "^4.0.0",
    "@sanity/image-url": "^1.2.0",
    "@sanity/preview-url-secret": "^2.1.14",
    "@sanity/vision": "^4.6.1",
    "@tailwindcss/postcss": "^4.1.13",
    "clsx": "^2.1.1",
    "feed": "^5.1.0",
    "framer-motion": "^12.23.12",
    "googleapis": "^159.0.0",
    "next": "^15.5.2",
    "next-sanity": "^10.0.16",
    "next-sanity-image": "^6.2.0",
    "nuqs": "^2.6.0",
    "octokit": "^5.0.3",
    "react": "^19.1.1",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-lite-youtube-embed": "^2.5.6",
    "resend": "^6.0.2",
    "rss-parser": "^3.13.0",
    "sanity": "^4.6.1",
    "sanity-plugin-dashboard-widget-vercel": "^3.1.4",
    "sanitypress-utils": "^0.0.8",
    "server-only": "^0.0.1",
    "shiki": "^3.12.2",
    "styled-components": "^6.1.19",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@next/eslint-plugin-next": "^15.5.2",
    "@sanity/eslint-config-studio": "^5.0.2",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
