    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "xml2js": "^0.6.2"
  },
  "overrides": {
    "sanitypress-utils": {
      "sanity": "4.4.1"
    }
