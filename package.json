{
  "name": "personal-blog",
  "version": "0.3.1",
  "description": "An impressive Sanity.io starter template with Next.js 15 and Tailwind 4",
  "author": "Abhimanyu Saharan <desk.abhimanyu@gmail.com> (https://blog.abhimanyu-saharan.com)",
  "scripts": {
    "dev": "next dev",
    "build": "npm run manifest && next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write src/ scripts/",
    "manifest": "sanity manifest extract --path public/admin/static",
    "typecheck": "tsc --noEmit",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node tests/run-tests.js"
  },
  "dependencies": {
    "@next/third-parties": "^15.5.2",
