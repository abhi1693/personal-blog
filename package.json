    "@sanity/preview-url-secret": "^4.0.2",
    "@sanity/vision": "^5.7.0",
    "@tailwindcss/postcss": "^4.1.18",
    "clsx": "^2.1.1",
    "feed": "^5.2.0",
    "framer-motion": "^12.29.2",
    "googleapis": "^170.1.0",
    "next": "16.1.6",
    "next-sanity": "^12.0.16",
